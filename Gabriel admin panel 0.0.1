----------------------------------------------------
-- RGB SLIDERS
----------------------------------------------------

local function createSlider(name, yPos)
    local label = Instance.new("TextLabel", panel)
    label.Size = UDim2.new(1,-20,0,20)
    label.Position = UDim2.new(0,10,0,yPos)
    label.BackgroundTransparency = 1
    label.Text = name .. ": 0"
    label.TextColor3 = Color3.fromRGB(255,255,255)
    label.Font = Enum.Font.GothamBold
    label.TextScaled = true

    local bg = Instance.new("Frame", panel)
    bg.Size = UDim2.new(1,-20,0,10)
    bg.Position = UDim2.new(0,10,0,yPos+25)
    bg.BackgroundColor3 = Color3.fromRGB(70,70,70)

    local btn = Instance.new("Frame", bg)
    btn.Size = UDim2.new(0,12,0,20)
    btn.Position = UDim2.new(0,0,-0.5,5)
    btn.BackgroundColor3 = Color3.fromRGB(255,255,255)

    return label, bg, btn
end

local rLabel, rBg, rBtn = createSlider("Red", 60)
local gLabel, gBg, gBtn = createSlider("Green", 120)
local bLabel, bBg, bBtn = createSlider("Blue", 180)

local dragging = nil

local function sliderLogic(btn, bg, label)
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = {btn=btn, bg=bg, label=label}
        end
    end)
end

sliderLogic(rBtn, rBg, rLabel)
sliderLogic(gBtn, gBg, gLabel)
sliderLogic(bBtn, bBg, bLabel)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = nil
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local mouseX = UIS:GetMouseLocation().X
        local barPos = dragging.bg.AbsolutePosition.X
        local barSize = dragging.bg.AbsoluteSize.X
        local percent = math.clamp((mouseX - barPos) / barSize, 0, 1)

        dragging.btn.Position = UDim2.new(percent, -6, -0.5, 5)
        local value = math.floor(percent * 255)
        dragging.label.Text = dragging.label.Text:split(":")[1] .. ": " .. value

        local r = tonumber(rLabel.Text:split(": ")[2])
        local g = tonumber(gLabel.Text:split(": ")[2])
        local b = tonumber(bLabel.Text:split(": ")[2])

        billboardText.TextColor3 = Color3.fromRGB(r,g,b)
    end
end)

