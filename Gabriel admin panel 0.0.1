----------------------------------------------------
-- FUNCTION: CREATE BILLBOARD ABOVE HEAD
----------------------------------------------------

local function createBillboard()
    local char = player.Character or player.CharacterAdded:Wait()
    local head = char:WaitForChild("Head")

    -- Remove old billboard if it exists
    if char:FindFirstChild("TitlePart") then
        char.TitlePart:Destroy()
    end

    -- Create invisible part above head
    local headPart = Instance.new("Part")
    headPart.Name = "TitlePart"
    headPart.Size = Vector3.new(1, 1, 1)
    headPart.Transparency = 1
    headPart.CanCollide = false
    headPart.Anchored = false
    headPart.Parent = char

    -- Weld to head
    local weld = Instance.new("WeldConstraint")
    weld.Part0 = head
    weld.Part1 = headPart
    weld.Parent = headPart

    -- Position above head
    headPart.CFrame = head.CFrame * CFrame.new(0, 1.5, 0)

    -- Billboard GUI
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "TitleBillboard"
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.AlwaysOnTop = true
    billboard.Adornee = headPart
    billboard.Parent = headPart

    -- Text
    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1, 0, 1, 0)
    text.BackgroundTransparency = 1
    text.Text = "Admin Title"
    text.TextScaled = true
    text.Font = Enum.Font.GothamBold
    text.TextColor3 = Color3.fromRGB(255, 255, 255)
    text.Parent = billboard

    return text
end

-- Create billboard on spawn
local billboardText = createBillboard()

-- Recreate billboard on respawn
player.CharacterAdded:Connect(function()
    task.wait(1)
    billboardText = createBillboard()
end)

